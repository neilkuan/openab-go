{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.25/MicrosoftTeams.schema.json",
  "manifestVersion": "1.25",
  "version": "1.0.2",
  "id": "{{MICROSOFT_APP_ID}}",
  "developer": {
    "name": "Quill",
    "websiteUrl": "https://github.com/neilkuan/quill",
    "privacyUrl": "https://github.com/neilkuan/quill/blob/main/PRIVACY.md",
    "termsOfUseUrl": "https://github.com/neilkuan/quill/blob/main/TERMS.md"
  },
  "name": {
    "short": "Quill",
    "full": "Quill AI Assistant"
  },
  "description": {
    "short": "AI chat bot powered by ACP agents",
    "full": "Quill is a multi-platform AI chat bot that proxies messages to an AI agent process via the Agent Communication Protocol (ACP). Supports streaming responses, image/voice/file attachments, and interactive bot commands."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#4F46E5",
  "bots": [
    {
      "botId": "{{MICROSOFT_APP_ID}}",
      "scopes": [
        "personal",
        "team",
        "groupChat"
      ],
      "isNotificationOnly": false,
      "supportsCalling": false,
      "supportsVideo": false,
      "supportsFiles": true,
      "commandLists": [
        {
          "scopes": [
            "personal",
            "team",
            "groupChat"
          ],
          "commands": [
            {
              "title": "sessions",
              "description": "List active ACP sessions"
            },
            {
              "title": "info",
              "description": "Show current session details"
            },
            {
              "title": "reset",
              "description": "Reset current session"
            },
            {
              "title": "resume",
              "description": "Resume the last session"
            },
            {
              "title": "stop",
              "description": "Cancel the current reply"
            },
            {
              "title": "pick",
              "description": "Browse and resume historical sessions"
            },
            {
              "title": "mode",
              "description": "Switch agent mode"
            },
            {
              "title": "model",
              "description": "Switch LLM model"
            },
            {
              "title": "help",
              "description": "Show available commands"
            }
          ]
        }
      ]
    }
  ],
  "defaultGroupCapability": {
    "team": "bot",
    "groupchat": "bot",
    "meetings": "bot"
  },
  "supportsChannelFeatures": "tier1",
  "permissions": [
    "messageTeamMembers"
  ],
  "validDomains": []
}
